{
	"name": "wp-agent",
	"version": "1.0.0-alpha",
	"description": "AI-powered admin assistant for WordPress",
	"main": "index.js",
	"scripts": {
		"start": "wp-scripts start",
		"build": "wp-scripts build",
		"i18n": "grunt textdomain && wp i18n make-pot languages/wp-agent.pot --domain=wp-agent --debug",
		"pretty": "prettier --check .",
		"pretty:fix": "prettier --write .",
		"lint-js": "wp-scripts lint-js",
		"lint-js:fix": "npm run pretty:fix && npm run lint-js -- --fix",
		"lint-css": "wp-scripts lint-style --allow-empty-input",
		"lint-css:fix": "npm run lint-css -- --fix",
		"lint-pkg-json": "wp-scripts lint-pkg-json",
		"packages-update": "wp-scripts packages-update",
		"check-engines": "wp-scripts check-engines",
		"check-licenses": "wp-scripts check-licenses",
		"format": "wp-scripts format",
		"lint:md:docs": "wp-scripts lint-md-docs",
		"lint:md:js": "wp-scripts lint-md-js",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"plugin-zip": "wp-scripts plugin-zip",
		"test:e2e": "wp-scripts test-e2e",
		"test:unit": "wp-scripts test-unit-js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/akshayurankar48/WP-AGENT.git"
	},
	"author": "Brainstorm Force",
	"license": "GPL-2.0-or-later",
	"bugs": {
		"url": "https://github.com/akshayurankar48/WP-AGENT/issues"
	},
	"homepage": "https://github.com/akshayurankar48/WP-AGENT#readme",
	"dependencies": {
		"@bsf/force-ui": "git+https://github.com/brainstormforce/force-ui.git#1.7.9",
		"clsx": "^2.1.1",
		"lucide-react": "^0.417.0",
		"tailwind-merge": "^2.4.0"
	},
	"devDependencies": {
		"@wordpress/scripts": "^27.0.0",
		"autoprefixer": "^10.4.19",
		"grunt": "^1.4.1",
		"grunt-cli": "^1.4.3",
		"grunt-contrib-clean": "^2.0.0",
		"grunt-contrib-compress": "^2.0.0",
		"grunt-contrib-copy": "^1.0.0",
		"tailwindcss": "^3.4.10",
		"wp-prettier": "^2.6.2"
	}
}
