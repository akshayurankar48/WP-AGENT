    "basic_title": "Basic",
    "pro_title": "Pro",
    "feature_1": "Unlimited Projects",
    "feature_2": "Custom Domains",
    "feature_3": "Priority Support",
    "feature_4": "Advanced Analytics",
    "feature_5": "Team Collaboration",
    "feature_6": "API Access",
    "basic_1": "\u2713",
