{
  "id": "logo-bar",
  "name": "Logo Bar",
  "category": "logos",
  "description": "Row of partner or client logos with muted styling and optional heading on a light background",
  "variables": {
    "heading": "Trusted by Industry Leaders",
    "logo_1_url": "https://placehold.co/160x48/e5e7eb/9ca3af?text=Acme+Co",
    "logo_2_url": "https://placehold.co/160x48/e5e7eb/9ca3af?text=Globex",
    "logo_3_url": "https://placehold.co/160x48/e5e7eb/9ca3af?text=Initech",
    "logo_4_url": "https://placehold.co/160x48/e5e7eb/9ca3af?text=Umbrella",
    "logo_5_url": "https://placehold.co/160x48/e5e7eb/9ca3af?text=Wayne+Inc",
    "bg_color": "{{bg_light}}",
    "text_color": "{{text_muted}}"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "style": {
          "color": { "background": "{{bg_color}}" },
          "spacing": { "padding": { "top": "60px", "bottom": "60px", "left": "40px", "right": "40px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/paragraph",
          "attrs": {
            "align": "center",
            "style": {
              "typography": { "fontSize": "14px", "textTransform": "uppercase", "letterSpacing": "0.1em", "fontWeight": "600" },
              "color": { "text": "{{text_color}}" },
              "spacing": { "margin": { "bottom": "40px" } }
            }
          },
          "innerHTML": "{{heading}}"
        },
        {
          "blockName": "core/columns",
          "attrs": {
            "verticalAlignment": "center",
            "style": { "spacing": { "blockGap": { "left": "48px" } } }
          },
          "innerBlocks": [
            { "blockName": "core/column", "attrs": { "verticalAlignment": "center" }, "innerBlocks": [{ "blockName": "core/image", "attrs": { "url": "{{logo_1_url}}", "alt": "Partner logo", "align": "center", "style": { "filter": { "duotone": "unset" } } } }] },
            { "blockName": "core/column", "attrs": { "verticalAlignment": "center" }, "innerBlocks": [{ "blockName": "core/image", "attrs": { "url": "{{logo_2_url}}", "alt": "Partner logo", "align": "center" } }] },
            { "blockName": "core/column", "attrs": { "verticalAlignment": "center" }, "innerBlocks": [{ "blockName": "core/image", "attrs": { "url": "{{logo_3_url}}", "alt": "Partner logo", "align": "center" } }] },
            { "blockName": "core/column", "attrs": { "verticalAlignment": "center" }, "innerBlocks": [{ "blockName": "core/image", "attrs": { "url": "{{logo_4_url}}", "alt": "Partner logo", "align": "center" } }] },
            { "blockName": "core/column", "attrs": { "verticalAlignment": "center" }, "innerBlocks": [{ "blockName": "core/image", "attrs": { "url": "{{logo_5_url}}", "alt": "Partner logo", "align": "center" } }] }
          ]
        }
      ]
    }
  ]
}
