{
  "id": "blog-featured",
  "name": "Featured Blog Post",
  "category": "blog",
  "description": "Two-column featured blog post layout with large image on the left, category tag, title, excerpt, author, and read more button on the right",
  "variables": {
    "image": "https://placehold.co/800x500/e5e7eb/6b7280?text=Featured+Post",
    "category": "Featured Story",
    "title": "Rethinking How We Build for the Modern Web",
    "excerpt": "The web has changed. Users expect instant load times, seamless interactions, and designs that feel native to every device. We spent six months rebuilding our approach from the ground up, and the results speak for themselves.",
    "author": "Written by Elena Rodriguez",
    "button_text": "Read More",
    "bg_color": "{{bg_light}}",
    "text_color": "{{text_dark}}",
    "muted_color": "{{text_muted}}",
    "accent_color": "{{accent}}",
    "button_bg": "{{primary}}",
    "button_text_color": "{{bg_white}}"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "style": {
          "color": { "background": "{{bg_color}}" },
          "spacing": { "padding": { "top": "100px", "bottom": "100px", "left": "40px", "right": "40px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/columns",
          "attrs": {
            "verticalAlignment": "center",
            "style": { "spacing": { "blockGap": { "left": "60px" } } }
          },
          "innerBlocks": [
            {
              "blockName": "core/column",
              "attrs": { "width": "55%" },
              "innerBlocks": [
                {
                  "blockName": "core/image",
                  "attrs": {
                    "url": "{{image}}",
                    "alt": "{{title}}",
                    "style": { "border": { "radius": "16px" } },
                    "sizeSlug": "full"
                  }
                }
              ]
            },
            {
              "blockName": "core/column",
              "attrs": { "width": "45%" },
              "innerBlocks": [
                {
                  "blockName": "core/paragraph",
                  "attrs": {
                    "style": {
                      "typography": { "fontSize": "12px", "fontWeight": "600", "textTransform": "uppercase", "letterSpacing": "0.05em" },
                      "color": { "text": "{{accent_color}}" },
                      "spacing": { "margin": { "bottom": "16px" } }
                    }
                  },
                  "innerHTML": "{{category}}"
                },
                {
                  "blockName": "core/heading",
                  "attrs": {
                    "level": 2,
                    "style": {
                      "typography": { "fontSize": "32px", "fontWeight": "700", "lineHeight": "1.3", "letterSpacing": "-0.01em" },
                      "color": { "text": "{{text_color}}" },
                      "spacing": { "margin": { "bottom": "20px" } }
                    }
                  },
                  "innerHTML": "{{title}}"
                },
                {
                  "blockName": "core/paragraph",
                  "attrs": {
                    "style": {
                      "typography": { "fontSize": "16px", "lineHeight": "1.7" },
                      "color": { "text": "{{muted_color}}" },
                      "spacing": { "margin": { "bottom": "20px" } }
                    }
                  },
                  "innerHTML": "{{excerpt}}"
                },
                {
                  "blockName": "core/paragraph",
                  "attrs": {
                    "style": {
                      "typography": { "fontSize": "14px", "fontWeight": "500" },
                      "color": { "text": "{{muted_color}}" },
                      "spacing": { "margin": { "bottom": "28px" } }
                    }
                  },
                  "innerHTML": "{{author}}"
                },
                {
                  "blockName": "core/buttons",
                  "innerBlocks": [
                    {
                      "blockName": "core/button",
                      "attrs": {
                        "style": {
                          "color": { "background": "{{button_bg}}", "text": "{{button_text_color}}" },
                          "typography": { "fontSize": "15px", "fontWeight": "600" },
                          "border": { "radius": "8px" },
                          "spacing": { "padding": { "top": "14px", "bottom": "14px", "left": "28px", "right": "28px" } }
                        }
                      },
                      "innerHTML": "{{button_text}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}