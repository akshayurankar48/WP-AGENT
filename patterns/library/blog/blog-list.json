{
  "id": "blog-list",
  "name": "Blog List Layout",
  "category": "blog",
  "description": "Vertical blog list with heading, three rows of text and image side by side, separated by borders on a white background",
  "variables": {
    "heading": "Recent Articles",
    "post_1_category": "Design",
    "post_1_title": "The Art of Minimalist Web Design in 2025",
    "post_1_excerpt": "Less is more. We explore how stripping away the unnecessary creates experiences that feel both elegant and effortless for every visitor.",
    "post_1_image": "https://placehold.co/400x260/e5e7eb/6b7280?text=Article+1",
    "post_2_category": "Technology",
    "post_2_title": "Building Accessible Products That Everyone Can Use",
    "post_2_excerpt": "Accessibility is not an afterthought. Learn how we bake inclusive design into every stage of our product development process from day one.",
    "post_2_image": "https://placehold.co/400x260/e5e7eb/6b7280?text=Article+2",
    "post_3_category": "Strategy",
    "post_3_title": "Why Customer Feedback Drives Our Product Roadmap",
    "post_3_excerpt": "Every feature we ship starts with a conversation. Here is how we turn real user feedback into the improvements that matter most.",
    "post_3_image": "https://placehold.co/400x260/e5e7eb/6b7280?text=Article+3",
    "bg_color": "{{bg_white}}",
    "text_color": "{{text_dark}}",
    "muted_color": "{{text_muted}}",
    "accent_color": "{{accent}}",
    "border_color": "{{border_light}}"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "style": {
          "color": { "background": "{{bg_color}}" },
          "spacing": { "padding": { "top": "100px", "bottom": "100px", "left": "40px", "right": "40px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/heading",
          "attrs": {
            "textAlign": "center",
            "level": 2,
            "style": {
              "typography": { "fontSize": "42px", "fontWeight": "700", "letterSpacing": "-0.02em" },
              "color": { "text": "{{text_color}}" },
              "spacing": { "margin": { "bottom": "64px" } }
            }
          },
          "innerHTML": "{{heading}}"
        },
        {
          "blockName": "core/group",
          "attrs": {
            "style": {
              "border": { "bottom": { "color": "{{border_color}}", "width": "1px", "style": "solid" } },
              "spacing": { "padding": { "bottom": "40px", "top": "0px" }, "margin": { "bottom": "40px" } }
            }
          },
          "innerBlocks": [
            {
              "blockName": "core/columns",
              "attrs": { "verticalAlignment": "center", "style": { "spacing": { "blockGap": { "left": "40px" } } } },
              "innerBlocks": [
                {
                  "blockName": "core/column",
                  "attrs": { "width": "70%" },
                  "innerBlocks": [
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "12px", "fontWeight": "600", "textTransform": "uppercase", "letterSpacing": "0.05em" },
                          "color": { "text": "{{accent_color}}" },
                          "spacing": { "margin": { "bottom": "8px" } }
                        }
                      },
                      "innerHTML": "{{post_1_category}}"
                    },
                    {
                      "blockName": "core/heading",
                      "attrs": {
                        "level": 3,
                        "style": {
                          "typography": { "fontSize": "24px", "fontWeight": "600", "lineHeight": "1.3" },
                          "color": { "text": "{{text_color}}" },
                          "spacing": { "margin": { "bottom": "12px" } }
                        }
                      },
                      "innerHTML": "{{post_1_title}}"
                    },
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "16px", "lineHeight": "1.7" },
                          "color": { "text": "{{muted_color}}" }
                        }
                      },
                      "innerHTML": "{{post_1_excerpt}}"
                    }
                  ]
                },
                {
                  "blockName": "core/column",
                  "attrs": { "width": "30%" },
                  "innerBlocks": [
                    {
                      "blockName": "core/image",
                      "attrs": {
                        "url": "{{post_1_image}}",
                        "alt": "{{post_1_title}}",
                        "style": { "border": { "radius": "12px" } },
                        "sizeSlug": "full"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "blockName": "core/group",
          "attrs": {
            "style": {
              "border": { "bottom": { "color": "{{border_color}}", "width": "1px", "style": "solid" } },
              "spacing": { "padding": { "bottom": "40px" }, "margin": { "bottom": "40px" } }
            }
          },
          "innerBlocks": [
            {
              "blockName": "core/columns",
              "attrs": { "verticalAlignment": "center", "style": { "spacing": { "blockGap": { "left": "40px" } } } },
              "innerBlocks": [
                {
                  "blockName": "core/column",
                  "attrs": { "width": "70%" },
                  "innerBlocks": [
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "12px", "fontWeight": "600", "textTransform": "uppercase", "letterSpacing": "0.05em" },
                          "color": { "text": "{{accent_color}}" },
                          "spacing": { "margin": { "bottom": "8px" } }
                        }
                      },
                      "innerHTML": "{{post_2_category}}"
                    },
                    {
                      "blockName": "core/heading",
                      "attrs": {
                        "level": 3,
                        "style": {
                          "typography": { "fontSize": "24px", "fontWeight": "600", "lineHeight": "1.3" },
                          "color": { "text": "{{text_color}}" },
                          "spacing": { "margin": { "bottom": "12px" } }
                        }
                      },
                      "innerHTML": "{{post_2_title}}"
                    },
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "16px", "lineHeight": "1.7" },
                          "color": { "text": "{{muted_color}}" }
                        }
                      },
                      "innerHTML": "{{post_2_excerpt}}"
                    }
                  ]
                },
                {
                  "blockName": "core/column",
                  "attrs": { "width": "30%" },
                  "innerBlocks": [
                    {
                      "blockName": "core/image",
                      "attrs": {
                        "url": "{{post_2_image}}",
                        "alt": "{{post_2_title}}",
                        "style": { "border": { "radius": "12px" } },
                        "sizeSlug": "full"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "blockName": "core/group",
          "innerBlocks": [
            {
              "blockName": "core/columns",
              "attrs": { "verticalAlignment": "center", "style": { "spacing": { "blockGap": { "left": "40px" } } } },
              "innerBlocks": [
                {
                  "blockName": "core/column",
                  "attrs": { "width": "70%" },
                  "innerBlocks": [
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "12px", "fontWeight": "600", "textTransform": "uppercase", "letterSpacing": "0.05em" },
                          "color": { "text": "{{accent_color}}" },
                          "spacing": { "margin": { "bottom": "8px" } }
                        }
                      },
                      "innerHTML": "{{post_3_category}}"
                    },
                    {
                      "blockName": "core/heading",
                      "attrs": {
                        "level": 3,
                        "style": {
                          "typography": { "fontSize": "24px", "fontWeight": "600", "lineHeight": "1.3" },
                          "color": { "text": "{{text_color}}" },
                          "spacing": { "margin": { "bottom": "12px" } }
                        }
                      },
                      "innerHTML": "{{post_3_title}}"
                    },
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "16px", "lineHeight": "1.7" },
                          "color": { "text": "{{muted_color}}" }
                        }
                      },
                      "innerHTML": "{{post_3_excerpt}}"
                    }
                  ]
                },
                {
                  "blockName": "core/column",
                  "attrs": { "width": "30%" },
                  "innerBlocks": [
                    {
                      "blockName": "core/image",
                      "attrs": {
                        "url": "{{post_3_image}}",
                        "alt": "{{post_3_title}}",
                        "style": { "border": { "radius": "12px" } },
                        "sizeSlug": "full"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}