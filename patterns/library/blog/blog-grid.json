                          "blockName": "core/paragraph",
                          "attrs": {
                            "style": {
                              "typography": { "fontSize": "14px", "fontWeight": "600" },
                              "color": { "text": "{{accent_color}}" }
                            }
                          },
                          "innerHTML": "Read More \u2192"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "blockName": "core/column",
              "innerBlocks": [
                {
                  "blockName": "core/group",
                  "attrs": {
                    "style": {
                      "color": { "background": "{{card_bg}}" },
                      "border": { "radius": "16px" },
                      "spacing": { "padding": { "bottom": "32px" } }
                    }
                  },
                  "innerBlocks": [
                    {
                      "blockName": "core/image",
                      "attrs": {
                        "url": "{{post_3_image}}",
                        "alt": "{{post_3_title}}",
                        "style": { "border": { "radius": "16px 16px 0px 0px" } },
                        "sizeSlug": "full"
                      }
                    },
                    {
                      "blockName": "core/group",
                      "attrs": { "style": { "spacing": { "padding": { "left": "24px", "right": "24px" } } } },
                      "innerBlocks": [
                        {
                          "blockName": "core/paragraph",
                          "attrs": {
                            "style": {
                              "typography": { "fontSize": "12px", "fontWeight": "600", "textTransform": "uppercase", "letterSpacing": "0.05em" },
                              "color": { "text": "{{accent_color}}" },
                              "spacing": { "margin": { "top": "20px", "bottom": "12px" } }
                            }
                          },
                          "innerHTML": "{{post_3_category}}"
                        },
                        {
                          "blockName": "core/heading",
                          "attrs": {
                            "level": 3,
                            "style": {
                              "typography": { "fontSize": "20px", "fontWeight": "600", "lineHeight": "1.4" },
                              "color": { "text": "{{text_color}}" },
                              "spacing": { "margin": { "bottom": "12px" } }
                            }
                          },
                          "innerHTML": "{{post_3_title}}"
                        },
                        {
