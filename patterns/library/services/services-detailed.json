                    "style": {
                      "typography": { "fontSize": "16px", "lineHeight": "1.7" },
                      "color": { "text": "{{muted_color}}" },
                      "spacing": { "margin": { "bottom": "24px" } }
                    }
                  },
                  "innerHTML": "{{service_2_desc}}"
                },
                {
                  "blockName": "core/list",
                  "attrs": {
                    "style": {
                      "typography": { "fontSize": "15px", "lineHeight": "2" },
                      "color": { "text": "{{text_color}}" }
                    }
                  },
                  "innerBlocks": [
                    { "blockName": "core/list-item", "innerHTML": "{{service_2_bullet_1}}" },
                    { "blockName": "core/list-item", "innerHTML": "{{service_2_bullet_2}}" },
                    { "blockName": "core/list-item", "innerHTML": "{{service_2_bullet_3}}" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "blockName": "core/columns",
          "attrs": {
            "verticalAlignment": "center",
            "style": { "spacing": { "blockGap": { "left": "60px" } } }
          },
          "innerBlocks": [
            {
              "blockName": "core/column",
              "attrs": { "width": "50%", "verticalAlignment": "center" },
              "innerBlocks": [
                {
                  "blockName": "core/heading",
                  "attrs": {
                    "level": 3,
                    "style": {
                      "typography": { "fontSize": "28px", "fontWeight": "700", "lineHeight": "1.3" },
                      "color": { "text": "{{text_color}}" },
                      "spacing": { "margin": { "bottom": "16px" } }
                    }
                  },
                  "innerHTML": "{{service_3_title}}"
                },
                {
                  "blockName": "core/paragraph",
                  "attrs": {
                    "style": {
                      "typography": { "fontSize": "16px", "lineHeight": "1.7" },
                      "color": { "text": "{{muted_color}}" },
                      "spacing": { "margin": { "bottom": "24px" } }
                    }
                  },
                  "innerHTML": "{{service_3_desc}}"
                },
                {
                  "blockName": "core/list",
                  "attrs": {
                    "style": {
                      "typography": { "fontSize": "15px", "lineHeight": "2" },
                      "color": { "text": "{{text_color}}" }
                    }
                  },
                  "innerBlocks": [
                    { "blockName": "core/list-item", "innerHTML": "{{service_3_bullet_1}}" },
                    { "blockName": "core/list-item", "innerHTML": "{{service_3_bullet_2}}" },
                    { "blockName": "core/list-item", "innerHTML": "{{service_3_bullet_3}}" }
                  ]
                }
              ]
            },
            {
              "blockName": "core/column",
              "attrs": { "width": "50%", "verticalAlignment": "center" },
              "innerBlocks": [
                {
                  "blockName": "core/image",
                  "attrs": {
                    "url": "{{service_3_image}}",
                    "alt": "{{service_3_title}}",
                    "style": { "border": { "radius": "16px" } },
                    "sizeSlug": "full"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}