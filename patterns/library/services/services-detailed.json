{
  "id": "services-detailed",
  "name": "Detailed Services Section",
  "category": "services",
  "description": "Three stacked alternating rows with text and image on opposite sides, each featuring heading, description, and feature bullets on a light background",
  "variables": {
    "heading": "Everything You Need",
    "subheading": "From concept to launch, we provide end-to-end solutions tailored to your business.",
    "service_1_title": "Custom Web Applications",
    "service_1_desc": "We design and build web applications that solve real problems. Our team works closely with you to understand your workflows, then creates intuitive tools your team will actually enjoy using.",
    "service_1_bullet_1": "Responsive design for every screen size",
    "service_1_bullet_2": "Real-time collaboration features",
    "service_1_bullet_3": "Built-in analytics and reporting",
    "service_1_image": "https://placehold.co/600x400/e5e7eb/6b7280?text=Web+Apps",
    "service_2_title": "Cloud Infrastructure",
    "service_2_desc": "Reliable, scalable infrastructure that handles traffic spikes without breaking a sweat. We set up, monitor, and maintain everything so your team can focus on building great products.",
    "service_2_bullet_1": "Auto-scaling for peak demand",
    "service_2_bullet_2": "99.99% uptime guarantee",
    "service_2_bullet_3": "24/7 monitoring and incident response",
    "service_2_image": "https://placehold.co/600x400/e5e7eb/6b7280?text=Cloud",
    "service_3_title": "Data Analytics & Insights",
    "service_3_desc": "Turn raw data into actionable insights. We build custom dashboards and reporting tools that help you understand your customers, optimize operations, and make confident decisions.",
    "service_3_bullet_1": "Custom dashboards and visualizations",
    "service_3_bullet_2": "Automated reporting pipelines",
    "service_3_bullet_3": "Predictive analytics and forecasting",
    "service_3_image": "https://placehold.co/600x400/e5e7eb/6b7280?text=Analytics",
    "bg_color": "{{bg_light}}",
    "text_color": "{{text_dark}}",
    "muted_color": "{{text_muted}}",
    "accent_color": "{{primary}}"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "style": {
          "color": { "background": "{{bg_color}}" },
          "spacing": { "padding": { "top": "100px", "bottom": "100px", "left": "40px", "right": "40px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/heading",
          "attrs": {
            "textAlign": "center",
            "level": 2,
            "style": {
              "typography": { "fontSize": "42px", "fontWeight": "700", "letterSpacing": "-0.02em" },
              "color": { "text": "{{text_color}}" },
              "spacing": { "margin": { "bottom": "16px" } }
            }
          },
          "innerHTML": "{{heading}}"
        },
        {
          "blockName": "core/paragraph",
          "attrs": {
            "align": "center",
            "style": {
              "typography": { "fontSize": "18px" },
              "color": { "text": "{{muted_color}}" },
              "spacing": { "margin": { "bottom": "80px" } }
            }
          },
          "innerHTML": "{{subheading}}"
        },
        {
          "blockName": "core/columns",
          "attrs": {
            "verticalAlignment": "center",
            "style": { "spacing": { "blockGap": { "left": "60px" }, "margin": { "bottom": "80px" } } }
          },
          "innerBlocks": [
            {
              "blockName": "core/column",
              "attrs": { "width": "50%", "verticalAlignment": "center" },
              "innerBlocks": [
                {
                  "blockName": "core/heading",
                  "attrs": {
                    "level": 3,
                    "style": {
                      "typography": { "fontSize": "28px", "fontWeight": "700", "lineHeight": "1.3" },
                      "color": { "text": "{{text_color}}" },
                      "spacing": { "margin": { "bottom": "16px" } }
                    }
                  },
                  "innerHTML": "{{service_1_title}}"
                },
                {
                  "blockName": "core/paragraph",
                  "attrs": {
                    "style": {
                      "typography": { "fontSize": "16px", "lineHeight": "1.7" },
                      "color": { "text": "{{muted_color}}" },
                      "spacing": { "margin": { "bottom": "24px" } }
                    }
                  },
                  "innerHTML": "{{service_1_desc}}"
                },
                {
                  "blockName": "core/list",
                  "attrs": {
                    "style": {
                      "typography": { "fontSize": "15px", "lineHeight": "2" },
                      "color": { "text": "{{text_color}}" }
                    }
                  },
                  "innerBlocks": [
                    { "blockName": "core/list-item", "innerHTML": "{{service_1_bullet_1}}" },
                    { "blockName": "core/list-item", "innerHTML": "{{service_1_bullet_2}}" },
                    { "blockName": "core/list-item", "innerHTML": "{{service_1_bullet_3}}" }
                  ]
                }
              ]
            },
            {
              "blockName": "core/column",
              "attrs": { "width": "50%", "verticalAlignment": "center" },
              "innerBlocks": [
                {
                  "blockName": "core/image",
                  "attrs": {
                    "url": "{{service_1_image}}",
                    "alt": "{{service_1_title}}",
                    "style": { "border": { "radius": "16px" } },
                    "sizeSlug": "full"
                  }
                }
              ]
            }
          ]
        },
        {
          "blockName": "core/columns",
          "attrs": {
            "verticalAlignment": "center",
            "style": { "spacing": { "blockGap": { "left": "60px" }, "margin": { "bottom": "80px" } } }
          },
          "innerBlocks": [
            {
              "blockName": "core/column",
              "attrs": { "width": "50%", "verticalAlignment": "center" },
              "innerBlocks": [
                {
                  "blockName": "core/image",
                  "attrs": {
                    "url": "{{service_2_image}}",
                    "alt": "{{service_2_title}}",
                    "style": { "border": { "radius": "16px" } },
                    "sizeSlug": "full"
                  }
                }
              ]
            },
            {
              "blockName": "core/column",
              "attrs": { "width": "50%", "verticalAlignment": "center" },
              "innerBlocks": [
                {
                  "blockName": "core/heading",
                  "attrs": {
                    "level": 3,
                    "style": {
                      "typography": { "fontSize": "28px", "fontWeight": "700", "lineHeight": "1.3" },
                      "color": { "text": "{{text_color}}" },
                      "spacing": { "margin": { "bottom": "16px" } }
                    }
                  },
                  "innerHTML": "{{service_2_title}}"
                },
                {
                  "blockName": "core/paragraph",
