                        "style": {
                          "typography": { "fontSize": "14px", "fontWeight": "600" },
                          "color": { "text": "{{accent_color}}" }
                        }
                      },
                      "innerHTML": "Learn More \u2192"
                    }
                  ]
                }
              ]
            },
            {
              "blockName": "core/column",
              "innerBlocks": [
                {
                  "blockName": "core/group",
                  "attrs": {
                    "style": {
                      "color": { "background": "{{card_bg}}" },
                      "border": { "radius": "16px" },
                      "spacing": { "padding": { "top": "36px", "bottom": "36px", "left": "32px", "right": "32px" } }
                    }
                  },
                  "innerBlocks": [
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "48px" },
                          "spacing": { "margin": { "bottom": "20px" } }
                        }
                      },
                      "innerHTML": "{{service_3_icon}}"
                    },
                    {
                      "blockName": "core/heading",
                      "attrs": {
                        "level": 3,
                        "style": {
                          "typography": { "fontSize": "22px", "fontWeight": "600" },
                          "color": { "text": "{{text_color}}" },
                          "spacing": { "margin": { "bottom": "12px" } }
                        }
                      },
                      "innerHTML": "{{service_3_title}}"
                    },
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "15px", "lineHeight": "1.7" },
                          "color": { "text": "{{muted_color}}" },
                          "spacing": { "margin": { "bottom": "20px" } }
                        }
                      },
                      "innerHTML": "{{service_3_desc}}"
                    },
                    {
                      "blockName": "core/paragraph",
                      "attrs": {
                        "style": {
                          "typography": { "fontSize": "14px", "fontWeight": "600" },
                          "color": { "text": "{{accent_color}}" }
                        }
                      },
                      "innerHTML": "Learn More \u2192"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
