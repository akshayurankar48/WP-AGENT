{
  "id": "divider-angle",
  "name": "Angle Divider",
  "category": "dividers",
  "description": "Angled section divider with gradient background creating a visual diagonal transition",
  "variables": {
    "top_color": "{{bg_light}}",
    "bottom_color": "{{bg_dark}}",
    "accent_color": "{{primary}}"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "style": {
          "color": {
            "gradient": "linear-gradient(170deg, {{top_color}} 45%, {{bottom_color}} 45.1%)"
          },
          "spacing": { "padding": { "top": "40px", "bottom": "40px", "left": "40px", "right": "40px" }, "margin": { "top": "0px", "bottom": "0px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/group",
          "attrs": {
            "style": {
              "spacing": { "padding": { "top": "20px", "bottom": "20px" } }
            },
            "layout": { "type": "flex", "justifyContent": "center" }
          },
          "innerBlocks": [
            {
              "blockName": "core/separator",
              "attrs": {
                "style": {
                  "color": { "background": "{{accent_color}}" },
                  "layout": { "selfStretch": "fixed", "flexSize": "80px" }
                },
                "className": "is-style-wide"
              },
              "innerHTML": "<hr class=\"wp-block-separator has-text-color has-background is-style-wide\"/>"
            }
          ]
        }
      ]
    }
  ]
}