{
  "id": "faq-two-col",
  "name": "Two-Column FAQ",
  "category": "faq",
  "description": "Two-column FAQ layout with heading and subtitle at top, 6 Q&As split across two columns using core/details blocks",
  "variables": {
    "heading": "Frequently Asked Questions",
    "subheading": "Find answers to the most common questions about our platform, pricing, and support.",
    "q1": "What is included in the free plan?",
    "a1": "The free plan includes up to 3 projects, 500 API calls per month, community support, and access to all core features. No credit card required to get started.",
    "q2": "How does billing work?",
    "a2": "We bill monthly or annually — your choice. Annual plans save you 20%. You can switch between plans at any time, and changes take effect on your next billing cycle.",
    "q3": "Can I import data from other tools?",
    "a3": "Yes. We support one-click imports from Notion, Airtable, Trello, Asana, and CSV files. Our migration wizard handles the mapping automatically so nothing gets lost.",
    "q4": "Is my data secure?",
    "a4": "Absolutely. All data is encrypted at rest with AES-256 and in transit with TLS 1.3. We are SOC 2 Type II certified and undergo regular third-party security audits.",
    "q5": "Do you offer a service-level agreement?",
    "a5": "Yes. Pro plans include a 99.9% uptime SLA. Enterprise plans come with a 99.99% SLA, priority incident response, and a dedicated technical account manager.",
    "q6": "How do I contact support?",
    "a6": "Free users can reach us through our community forum. Pro users get email support with 4-hour response times. Enterprise customers have 24/7 phone and Slack support.",
    "bg_color": "{{bg_light}}",
    "text_color": "{{text_dark}}",
    "muted_color": "{{text_muted}}",
    "border_color": "{{border_light}}"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "style": {
          "color": { "background": "{{bg_color}}" },
          "spacing": { "padding": { "top": "100px", "bottom": "100px", "left": "40px", "right": "40px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/heading",
          "attrs": { "textAlign": "center", "level": 2, "style": { "typography": { "fontSize": "42px", "fontWeight": "700", "letterSpacing": "-0.02em" }, "color": { "text": "{{text_color}}" }, "spacing": { "margin": { "bottom": "16px" } } } },
          "innerHTML": "{{heading}}"
        },
        {
          "blockName": "core/paragraph",
          "attrs": { "align": "center", "style": { "typography": { "fontSize": "18px", "lineHeight": "1.6" }, "color": { "text": "{{muted_color}}" }, "spacing": { "margin": { "bottom": "64px" } } } },
          "innerHTML": "{{subheading}}"
        },
        {
          "blockName": "core/columns",
          "attrs": { "style": { "spacing": { "blockGap": { "left": "48px" } } } },
          "innerBlocks": [
            {
              "blockName": "core/column",
              "attrs": {},
              "innerBlocks": [
                {
                  "blockName": "core/details",
                  "attrs": { "summary": "{{q1}}", "style": { "spacing": { "padding": { "top": "20px", "bottom": "20px" } }, "border": { "bottom": { "width": "1px", "color": "{{border_color}}" } }, "typography": { "fontSize": "17px", "fontWeight": "600" } } },
                  "innerBlocks": [
                    { "blockName": "core/paragraph", "attrs": { "style": { "typography": { "fontSize": "15px", "lineHeight": "1.7" }, "color": { "text": "{{muted_color}}" } } }, "innerHTML": "{{a1}}" }
                  ]
                },
                {
                  "blockName": "core/details",
                  "attrs": { "summary": "{{q2}}", "style": { "spacing": { "padding": { "top": "20px", "bottom": "20px" } }, "border": { "bottom": { "width": "1px", "color": "{{border_color}}" } }, "typography": { "fontSize": "17px", "fontWeight": "600" } } },
                  "innerBlocks": [
                    { "blockName": "core/paragraph", "attrs": { "style": { "typography": { "fontSize": "15px", "lineHeight": "1.7" }, "color": { "text": "{{muted_color}}" } } }, "innerHTML": "{{a2}}" }
                  ]
                },
                {
                  "blockName": "core/details",
                  "attrs": { "summary": "{{q3}}", "style": { "spacing": { "padding": { "top": "20px", "bottom": "20px" } }, "border": { "bottom": { "width": "1px", "color": "{{border_color}}" } }, "typography": { "fontSize": "17px", "fontWeight": "600" } } },
                  "innerBlocks": [
                    { "blockName": "core/paragraph", "attrs": { "style": { "typography": { "fontSize": "15px", "lineHeight": "1.7" }, "color": { "text": "{{muted_color}}" } } }, "innerHTML": "{{a3}}" }
                  ]
                }
              ]
            },
            {
              "blockName": "core/column",
              "attrs": {},
              "innerBlocks": [
                {
                  "blockName": "core/details",
                  "attrs": { "summary": "{{q4}}", "style": { "spacing": { "padding": { "top": "20px", "bottom": "20px" } }, "border": { "bottom": { "width": "1px", "color": "{{border_color}}" } }, "typography": { "fontSize": "17px", "fontWeight": "600" } } },
                  "innerBlocks": [
                    { "blockName": "core/paragraph", "attrs": { "style": { "typography": { "fontSize": "15px", "lineHeight": "1.7" }, "color": { "text": "{{muted_color}}" } } }, "innerHTML": "{{a4}}" }
                  ]
                },
                {
                  "blockName": "core/details",
                  "attrs": { "summary": "{{q5}}", "style": { "spacing": { "padding": { "top": "20px", "bottom": "20px" } }, "border": { "bottom": { "width": "1px", "color": "{{border_color}}" } }, "typography": { "fontSize": "17px", "fontWeight": "600" } } },
                  "innerBlocks": [
                    { "blockName": "core/paragraph", "attrs": { "style": { "typography": { "fontSize": "15px", "lineHeight": "1.7" }, "color": { "text": "{{muted_color}}" } } }, "innerHTML": "{{a5}}" }
                  ]
                },
                {
                  "blockName": "core/details",
                  "attrs": { "summary": "{{q6}}", "style": { "spacing": { "padding": { "top": "20px", "bottom": "20px" } }, "border": { "bottom": { "width": "1px", "color": "{{border_color}}" } }, "typography": { "fontSize": "17px", "fontWeight": "600" } } },
                  "innerBlocks": [
                    { "blockName": "core/paragraph", "attrs": { "style": { "typography": { "fontSize": "15px", "lineHeight": "1.7" }, "color": { "text": "{{muted_color}}" } } }, "innerHTML": "{{a6}}" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
