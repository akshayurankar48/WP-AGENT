{
  "id": "stats-cards",
  "name": "Stats Cards Row",
  "category": "stats",
  "description": "Four-column stats cards with numbers and labels on light background with card styling",
  "variables": {
    "stat_1": "10M+",
    "label_1": "Downloads",
    "stat_2": "150+",
    "label_2": "Countries",
    "stat_3": "24/7",
    "label_3": "Support",
    "stat_4": "99.9%",
    "label_4": "Uptime",
    "bg_color": "{{bg_white}}",
    "card_bg": "{{bg_light}}",
    "number_color": "{{primary}}",
    "label_color": "{{text_muted}}"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "style": {
          "color": { "background": "{{bg_color}}" },
          "spacing": { "padding": { "top": "80px", "bottom": "80px", "left": "40px", "right": "40px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/columns",
          "attrs": { "style": { "spacing": { "blockGap": { "left": "24px" } } } },
          "innerBlocks": [
            { "blockName": "core/column", "innerBlocks": [{ "blockName": "core/group", "attrs": { "style": { "color": { "background": "{{card_bg}}" }, "spacing": { "padding": { "top": "32px", "bottom": "32px", "left": "24px", "right": "24px" } }, "border": { "radius": "12px" } } }, "innerBlocks": [
              { "blockName": "core/heading", "attrs": { "textAlign": "center", "level": 3, "style": { "typography": { "fontSize": "40px", "fontWeight": "800" }, "color": { "text": "{{number_color}}" } } }, "innerHTML": "{{stat_1}}" },
              { "blockName": "core/paragraph", "attrs": { "align": "center", "style": { "typography": { "fontSize": "14px", "textTransform": "uppercase", "letterSpacing": "0.05em" }, "color": { "text": "{{label_color}}" } } }, "innerHTML": "{{label_1}}" }
            ]}] },
            { "blockName": "core/column", "innerBlocks": [{ "blockName": "core/group", "attrs": { "style": { "color": { "background": "{{card_bg}}" }, "spacing": { "padding": { "top": "32px", "bottom": "32px", "left": "24px", "right": "24px" } }, "border": { "radius": "12px" } } }, "innerBlocks": [
              { "blockName": "core/heading", "attrs": { "textAlign": "center", "level": 3, "style": { "typography": { "fontSize": "40px", "fontWeight": "800" }, "color": { "text": "{{number_color}}" } } }, "innerHTML": "{{stat_2}}" },
              { "blockName": "core/paragraph", "attrs": { "align": "center", "style": { "typography": { "fontSize": "14px", "textTransform": "uppercase", "letterSpacing": "0.05em" }, "color": { "text": "{{label_color}}" } } }, "innerHTML": "{{label_2}}" }
            ]}] },
            { "blockName": "core/column", "innerBlocks": [{ "blockName": "core/group", "attrs": { "style": { "color": { "background": "{{card_bg}}" }, "spacing": { "padding": { "top": "32px", "bottom": "32px", "left": "24px", "right": "24px" } }, "border": { "radius": "12px" } } }, "innerBlocks": [
              { "blockName": "core/heading", "attrs": { "textAlign": "center", "level": 3, "style": { "typography": { "fontSize": "40px", "fontWeight": "800" }, "color": { "text": "{{number_color}}" } } }, "innerHTML": "{{stat_3}}" },
              { "blockName": "core/paragraph", "attrs": { "align": "center", "style": { "typography": { "fontSize": "14px", "textTransform": "uppercase", "letterSpacing": "0.05em" }, "color": { "text": "{{label_color}}" } } }, "innerHTML": "{{label_3}}" }
            ]}] },
            { "blockName": "core/column", "innerBlocks": [{ "blockName": "core/group", "attrs": { "style": { "color": { "background": "{{card_bg}}" }, "spacing": { "padding": { "top": "32px", "bottom": "32px", "left": "24px", "right": "24px" } }, "border": { "radius": "12px" } } }, "innerBlocks": [
              { "blockName": "core/heading", "attrs": { "textAlign": "center", "level": 3, "style": { "typography": { "fontSize": "40px", "fontWeight": "800" }, "color": { "text": "{{number_color}}" } } }, "innerHTML": "{{stat_4}}" },
              { "blockName": "core/paragraph", "attrs": { "align": "center", "style": { "typography": { "fontSize": "14px", "textTransform": "uppercase", "letterSpacing": "0.05em" }, "color": { "text": "{{label_color}}" } } }, "innerHTML": "{{label_4}}" }
            ]}] }
          ]
        }
      ]
    }
  ]
}
