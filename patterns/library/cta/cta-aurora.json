{
  "id": "cta-aurora",
  "name": "Aurora CTA Section",
  "category": "cta",
  "description": "Aurora animated background with noise overlay, large heading, and single glowing CTA button",
  "variables": {
    "heading": "Ready to Get Started?",
    "subheading": "Join thousands of teams building the future. Start free, no credit card required.",
    "cta_text": "Start Building Free",
    "bg_color": "#0c0c14",
    "text_color": "#ffffff",
    "muted_color": "#a1a1aa"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "className": "wpa-aurora wpa-noise",
        "style": {
          "color": { "background": "{{bg_color}}", "text": "{{text_color}}" },
          "spacing": { "padding": { "top": "120px", "bottom": "120px", "left": "40px", "right": "40px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/heading",
          "attrs": {
            "textAlign": "center",
            "level": 2,
            "style": { "typography": { "fontSize": "48px", "fontWeight": "700", "letterSpacing": "-0.02em" } }
          },
          "innerHTML": "{{heading}}"
        },
        {
          "blockName": "core/paragraph",
          "attrs": {
            "align": "center",
            "style": {
              "typography": { "fontSize": "18px", "lineHeight": "1.6" },
              "color": { "text": "{{muted_color}}" },
              "spacing": { "margin": { "top": "16px", "bottom": "40px" } }
            }
          },
          "innerHTML": "{{subheading}}"
        },
        {
          "blockName": "core/buttons",
          "attrs": { "layout": { "type": "flex", "justifyContent": "center" } },
          "innerBlocks": [
            {
              "blockName": "core/button",
              "attrs": {
                "className": "wpa-glow",
                "style": {
                  "color": { "background": "#6366f1", "text": "#ffffff" },
                  "typography": { "fontSize": "16px", "fontWeight": "600" },
                  "border": { "radius": "100px" },
                  "spacing": { "padding": { "top": "18px", "bottom": "18px", "left": "48px", "right": "48px" } }
                }
              },
              "innerHTML": "{{cta_text}}"
            }
          ]
        }
      ]
    }
  ]
}
