{
  "id": "cta-banner",
  "name": "CTA Banner",
  "category": "cta",
  "description": "Bold call-to-action banner with dark background, headline, subtitle, and two buttons",
  "variables": {
    "heading": "Ready to Get Started?",
    "subheading": "Join 10,000+ teams who shipped faster this quarter. Start your free trial — no credit card needed.",
    "cta_primary": "Start Free Trial",
    "cta_secondary": "Talk to Sales",
    "bg_color": "{{bg_dark}}",
    "accent_color": "{{primary}}"
  },
  "blocks": [
    {
      "blockName": "core/group",
      "attrs": {
        "align": "full",
        "style": {
          "color": { "background": "{{bg_color}}", "text": "#ffffff" },
          "spacing": { "padding": { "top": "100px", "bottom": "100px", "left": "40px", "right": "40px" } }
        },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "blockName": "core/heading",
          "attrs": { "textAlign": "center", "level": 2, "style": { "typography": { "fontSize": "42px", "fontWeight": "700" } } },
          "innerHTML": "{{heading}}"
        },
        {
          "blockName": "core/paragraph",
          "attrs": { "align": "center", "style": { "typography": { "fontSize": "20px" }, "color": { "text": "{{text_light}}" }, "spacing": { "margin": { "top": "16px", "bottom": "40px" } } } },
          "innerHTML": "{{subheading}}"
        },
        {
          "blockName": "core/buttons",
          "attrs": { "layout": { "type": "flex", "justifyContent": "center" } },
          "innerBlocks": [
            { "blockName": "core/button", "attrs": { "style": { "color": { "background": "{{accent_color}}", "text": "#ffffff" }, "typography": { "fontSize": "16px", "fontWeight": "600" }, "border": { "radius": "100px" }, "spacing": { "padding": { "top": "18px", "bottom": "18px", "left": "48px", "right": "48px" } } } }, "innerHTML": "{{cta_primary}}" },
            { "blockName": "core/button", "attrs": { "style": { "color": { "background": "transparent", "text": "#ffffff" }, "typography": { "fontSize": "16px", "fontWeight": "600" }, "border": { "radius": "100px", "width": "2px", "color": "#ffffff" }, "spacing": { "padding": { "top": "18px", "bottom": "18px", "left": "48px", "right": "48px" } } } }, "innerHTML": "{{cta_secondary}}" }
          ]
        }
      ]
    }
  ]
}
